[app]
loglevel=debug

[database]
dsn=postgresql+psycopg://postgres:postgres@pseudonym_db:5432/postgres

[telemetry]
enabled = True
endpoint = http://tracing:4317
service_name = pseudonym
tracer_name = zmodules.service.pseudonym

[uvicorn]
swagger_enabled = True
docs_url = /docs
redoc_url = /redocs
host = 0.0.0.0
port = 8504
reload = True

use_ssl = False
ssl_base_dir = secrets/ssl
ssl_cert_file = server.cert
ssl_key_file = server.key
